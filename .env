# Modo demo: la app corre con datos de ejemplo en memoria, sin Supabase.
# Para conectar la base real de BVR, define las dos variables de Supabase en
# un archivo .env.local (que NO se sube) y borra NEXT_PUBLIC_USE_MOCK.
NEXT_PUBLIC_USE_MOCK=true

# Placeholders para que el cliente de Supabase se inicialice sin error en modo
# demo (no se hace ninguna llamada real mientras USE_MOCK sea true).
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key
